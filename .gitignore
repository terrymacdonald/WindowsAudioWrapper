################################################################################
# Modern C# / .NET Tooling & Build Outputs
################################################################################

# User-specific files & local workspace states
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.suo.tmp

# Ensure Visual Studio's new XML solution format (.slnx) is NEVER ignored
!*.slnx

# Core .NET Build Results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
obj/
bin/

# Generated source files from source generators or incremental builds
Generated\ Files/

# Test architecture & code coverage outputs
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.executioncount
*.msvca
*.coverage
*.coveragexml

################################################################################
# Package Managers & Dependencies
################################################################################

# NuGet packages directory (modern projects restore to global cache, local is noise)
**/packages/*
!**/packages/build/
*.nupkg

# Paket dependency manager
.paket/

################################################################################
# IDE Tooling Ecosystems
################################################################################

# JetBrains Rider & ReSharper
.idea/
*.sln.iml
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Visual Studio Code
.vscode/
*.code-workspace
.history/
.ionide/

# Visual Studio Tools for Office
*.designer.cs.dll
*.designer.vb.dll

################################################################################
# Security & Local Configuration (Crucial for C#)
################################################################################

# Local user secrets or environment configurations
appsettings.Development.json
*.usersecrets
.env
.env.*
secrets.json

################################################################################
# Operating System Cleanups
################################################################################

# Windows image caches & folder preferences
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS metadata folders (critical if anyone opens the project on a Mac)
.DS_Store
.AppleDouble
.LSOverride
._*

################################################################################
# Legacy and Backup Discards
################################################################################

*.ilk
*.meta
*.pdb
*.tmp
*.tmp_proj
*.log
*.tlog
*.vspscc
*.vssscc
UpgradeLog.htm
_UpgradeReport_Files/
WindowsAudioWrapper.Tests/obj/project.assets.json
WindowsAudioWrapper.Tests/obj/project.nuget.cache
WindowsAudioWrapper.Tests/obj/WindowsAudioWrapper.Tests.csproj.nuget.dgspec.json
WindowsAudioWrapper/obj/project.assets.json
WindowsAudioWrapper/obj/project.nuget.cache
WindowsAudioWrapper/obj/WindowsAudioWrapper.csproj.nuget.dgspec.json
